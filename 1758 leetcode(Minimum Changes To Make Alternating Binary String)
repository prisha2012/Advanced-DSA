class Solution {
    public int minOperations(String s) {
        int flipStart=0;
        int flipstart=0;
        for(int i=0;i<s.length();i++){
            char e0=(i%2==0)?'0':'1';
            char e1 = (i % 2 == 0) ? '1' : '0';
            if(s.charAt(i)!=e0)flipStart++;
             if(s.charAt(i)!=e1)flipstart++;
        }
        return Math.min(flipStart,flipstart);

    }
}
